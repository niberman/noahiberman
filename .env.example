# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Get these from your Supabase project settings:
# https://app.supabase.com/project/[your-project]/settings/api

# Local Supabase: run `supabase start`, then `npm run env:from-supabase` to print
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY / VITE_SUPABASE_FUNCTIONS_URL from the CLI.
# Hosted: Dashboard -> Project Settings -> API (same three values).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional. Local FastAPI scheduling backend (slots, booking, Google OAuth exchange).
# On Vercel, this repo now serves those endpoints at same-origin (`/scheduling/*`),
# so you usually do not need VITE_API_BASE in production unless the backend lives elsewhere.
VITE_API_BASE=http://localhost:8000

# iNoah public chat (Supabase Edge Function proxy)
# Defaults use VITE_SUPABASE_URL if FUNCTIONS URL is not set
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co
VITE_INOAH_FUNCTION_PATH=/functions/v1/inoah-chat

# Sovereign Chat link in navigation (set to "true" to show)
VITE_ENABLE_CHAT_LINK=false

# iNoah Hands remote control (Dashboard) — must match AGENT_SECRET_KEY on the host
VITE_AGENT_URL=http://127.0.0.1:8000
VITE_AGENT_SECRET=1234
