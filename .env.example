# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Get these from your Supabase project settings:
# https://app.supabase.com/project/[your-project]/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# iNoah public chat (Supabase Edge Function proxy)
# Defaults use VITE_SUPABASE_URL if FUNCTIONS URL is not set
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co
VITE_INOAH_FUNCTION_PATH=/functions/v1/inoah-chat
