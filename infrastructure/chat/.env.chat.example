# ============================================================================
# iNoah Sovereign Chat — Environment Configuration
# ============================================================================
# Copy this file to .env.chat and fill in your values:
#   cp .env.chat.example .env.chat
# ============================================================================

# ── LM Studio (primary local model server) ──────────────────────────────────
# LM Studio exposes an OpenAI-compatible API on this port.
# host.docker.internal resolves to your Mac/PC host from inside Docker.
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# ── Open WebUI ───────────────────────────────────────────────────────────────
# Generate a secure key:  openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── External API Keys (optional) ────────────────────────────────────────────
# These can also be configured via the Open WebUI Admin Settings UI.
# Leave blank if you only want to use local LM Studio models.
OPENAI_API_KEY=lm-studio
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token for the tunnel that exposes this instance at chat.noahiberman.com.
# See README.md for instructions on creating a tunnel and obtaining a token.
TUNNEL_TOKEN=your-cloudflare-tunnel-token
